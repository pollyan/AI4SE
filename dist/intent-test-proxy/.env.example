# Native local-host proxy. Copy to .env and replace every placeholder.
INTENT_PROXY_TOPOLOGY=local-host
INTENT_PROXY_TOKEN=replace-with-a-random-token-of-at-least-32-bytes
INTENT_PUBLIC_ORIGIN=http://127.0.0.1:5001

OPENAI_API_KEY=your-api-key-here
OPENAI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
MIDSCENE_MODEL_NAME=qwen-vl-max-latest
MAIN_APP_URL=http://127.0.0.1:5001/intent-tester/api
PORT=3001
